---
import { getEntry, render } from "astro:content";
import BlogLayout from "@/layouts/BlogLayout.astro";

const entry = await getEntry("blog_en", "notion-migration-guide");

if (!entry) {
  throw new Error("Missing English notion-migration-guide blog entry");
}

const { Content } = await render(entry);
---

<BlogLayout
  frontmatter={entry.data}
  backHref="/en/"
  backLabel="Back to home"
  schemaType="Article"
>
  <Content />
</BlogLayout>
